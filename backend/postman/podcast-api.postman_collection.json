{
  "info": {
    "name": "Podcast API",
    "_postman_id": "c6de1758-0ed2-4f5d-8f24-43cf2f134d21",
    "description": "Postman collection for the podcast auth and session APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "recoveryId",
      "value": ""
    },
    {
      "key": "resetToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "API Endpoints",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/endpoints",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "endpoints"
          ]
        }
      }
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"demo@example.com\",\n  \"mobile\": \"9876543210\",\n  \"password\": \"secret123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identifier\": \"demo@example.com\",\n  \"password\": \"secret123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Forgot Request Email",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"channel\": \"email\",\n  \"email\": \"demo@example.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/forgot/request",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "forgot",
            "request"
          ]
        }
      }
    },
    {
      "name": "Forgot Request Mobile",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"channel\": \"mobile\",\n  \"mobile\": \"9876543210\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/forgot/request",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "forgot",
            "request"
          ]
        }
      }
    },
    {
      "name": "Forgot Verify OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"recoveryId\": \"{{recoveryId}}\",\n  \"otp\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/forgot/verify",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "forgot",
            "verify"
          ]
        }
      }
    },
    {
      "name": "Forgot Reset Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"recoveryId\": \"{{recoveryId}}\",\n  \"resetToken\": \"{{resetToken}}\",\n  \"newPassword\": \"newsecret123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/forgot/reset",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "forgot",
            "reset"
          ]
        }
      }
    },
    {
      "name": "Current User",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "me"
          ]
        }
      }
    },
    {
      "name": "Create Session",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"My Podcast Episode\",\n  \"hostLabel\": \"Speaker 1\",\n  \"guestLabel\": \"Speaker 2\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/sessions",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "sessions"
          ]
        }
      }
    },
    {
      "name": "List Sessions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/sessions",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "sessions"
          ]
        }
      }
    }
  ]
}
